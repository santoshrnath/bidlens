# =============================================================================
# BidLens — environment template
# =============================================================================
# Copy to `.env.local` and fill in. NEVER commit `.env.local`.
# `deploy/hetzner/deploy.sh` scp's your `.env.local` to the server as `.env`.
# =============================================================================

# ---- Anthropic (Claude) ---------------------------------------------------
# Required to enable live Claude-powered features (clarification drafting,
# schema extraction). Without it, BidLens still runs in demo mode — UI flows
# fall back to canned outputs so the partner walkthrough never breaks.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Database (Postgres) --------------------------------------------------
# Inside docker compose:
DATABASE_URL=postgresql://bidlens:bidlens@bidlens-db:5432/bidlens?schema=public

# ---- Deployment -----------------------------------------------------------
BIDLENS_PORT=3080
PUBLIC_HOSTNAME=bidlens.oneplaceplatform.com
TRAEFIK_NETWORK=coolify

# ---- Optional: Clerk (auth) ----------------------------------------------
# Leave empty to run BidLens open (suitable for the partner demo). Fill in
# to gate the app behind sign-in.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
SUPER_ADMIN_EMAILS=
